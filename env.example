# Copy to .env and fill in.  (PowerShell: copy env.example .env)
# Nothing is hardcoded anywhere else in the project.

# ---------------------------------------------------------------------------
# Identity -- REQUIRED for any data harvesting.
# ---------------------------------------------------------------------------
# SEC EDGAR mandates a descriptive User-Agent with a contact email and returns
# a 403 HTML page without one. It also blocks "unclassified bots", so this is
# what makes us a classified one. Use a real address you monitor.
USER_AGENT=scout/0.1 you@example.com

# ---------------------------------------------------------------------------
# LLM -- only needed for `scout research`, not for `scout harvest`.
# ---------------------------------------------------------------------------
# "anthropic"     -> native Messages API (thinking blocks, prompt cache control)
# "openai_compat" -> OpenAI, Ollama, LM Studio, vLLM, OpenRouter
LLM_PROVIDER=openai_compat
MODEL_NAME=
LLM_API_KEY=
# Leave empty for api.openai.com. Local examples:
#   Ollama     http://127.0.0.1:11434/v1
#   LM Studio  http://127.0.0.1:1234/v1
#   vLLM       http://127.0.0.1:8000/v1
#   OpenRouter https://openrouter.ai/api/v1
LLM_BASE_URL=
TEMPERATURE=0.2
MAX_TOKENS=4096
REQUEST_TIMEOUT_S=180

# Normalized reasoning budget: none | low | medium | high, or empty.
#
# Set "none" for hybrid-thinking local models (Qwen3.x, DeepSeek-R1). They think
# before answering by default, which for routine structured extraction is pure
# latency -- measured at 193x on this project's predecessor for an identical
# verdict. Leave EMPTY for models that reject the parameter; the adapter
# degrades gracefully on a 400 either way.
REASONING_EFFORT=

# ---------------------------------------------------------------------------
# Source credentials -- all optional. A source without its key is skipped with
# a warning rather than failing the harvest.
# ---------------------------------------------------------------------------
# Japan EDINET v2 -- free registration, https://api.edinet-fsa.go.jp/
EDINET_API_KEY=
# Korea OpenDART -- free, issued instantly, https://opendart.fss.or.kr/
OPENDART_API_KEY=
# UK Companies House -- free, https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=
# OpenFIGI -- optional; raises the limit from 25 to 250 req/min
OPENFIGI_API_KEY=

# ---------------------------------------------------------------------------
# Storage and execution
# ---------------------------------------------------------------------------
DATA_DIR=data
LLM_CACHE_DIR=.cache/llm
# Content-addressed replay cache. Keep it on: it makes runs resumable, lets you
# iterate on later pipeline stages offline, and makes prompt tests deterministic.
LLM_CACHE=true
CONCURRENCY=8
