# ============================================================
#  LLM PROVIDER (any OpenAI-compatible endpoint)
# ============================================================
# The bot uses the official `openai` npm package, so it works with:
#   - Ollama:     OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#   - LM Studio:  OPENAI_BASE_URL=http://127.0.0.1:1234/v1
#   - OpenAI:     leave OPENAI_BASE_URL empty (uses api.openai.com)
#   - Anthropic:  OPENAI_BASE_URL=https://api.anthropic.com/v1/  (OpenAI SDK compat layer)
#
# A remote box on your LAN works the same way -- just use its address:
#   OPENAI_BASE_URL=http://<host-ip>:11434/v1
#
# For local servers the API key is not checked -- any placeholder works.
OPENAI_API_KEY=unused
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
MODEL_NAME=your-model-name-here

# Sampling temperature for the analyst (keep low for consistency)
TEMPERATURE=0.2

# Hybrid-thinking models (Qwen3.x, DeepSeek-R1, GPT-OSS...) reason before
# answering BY DEFAULT. For structured output like this bot's JSON verdict
# that costs enormous latency for no benefit -- measured at 270s vs 1.4s
# against a local Qwen3.6-35B. Some servers also divert the answer into a
# non-standard "reasoning" field, leaving "content" empty.
#   none                -> disable thinking (required for Qwen3.x)
#   low / medium / high -> for reasoning models that genuinely need it
# Leave EMPTY to omit the parameter entirely (correct for gpt-4o, Claude and
# other providers that reject it).
REASONING_EFFORT=

# Abort a request that hangs longer than this (milliseconds).
REQUEST_TIMEOUT_MS=180000

# ============================================================
#  TRADINGVIEW DESKTOP BRIDGE (Chrome DevTools Protocol)
# ============================================================
# Launch TradingView Desktop with:  --remote-debugging-port=9222
CDP_HOST=127.0.0.1
CDP_PORT=9222

# ============================================================
#  BOT BEHAVIOUR
# ============================================================
# 0 = analyze once and exit. Any value > 0 (milliseconds) = keep
# re-analyzing on that interval (same as running with --watch).
POLL_INTERVAL_MS=0

# Where every interaction is appended (JSON Lines, for backtesting)
LOG_FILE=trades.log
