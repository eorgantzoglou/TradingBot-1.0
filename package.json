{
  "name": "tradingview-ai-bot",
  "version": "1.0.0",
  "description": "Local AI trading bot that bridges TradingView Desktop (via Chrome DevTools Protocol) with any OpenAI-compatible LLM for technical analysis and signal generation.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "watch": "node src/index.js --watch",
    "dry-run": "node src/index.js --dry-run --debug",
    "check:cdp": "node src/tools/check-cdp.js",
    "check:llm": "node src/tools/test-llm.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "puppeteer-core": "^25.3.0"
  }
}
